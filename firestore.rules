rules_version = '2';

// ─────────────────────────────────────────────────────────────
//  THE REAL SECURITY BOUNDARY.
//  Client-side checks are only for UX — these rules are what
//  actually stop anyone who is not the admin from writing data.
//
//  Deploy:  firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // Daftar email admin — samakan dengan NEXT_PUBLIC_ADMIN_EMAILS di .env.local
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['damtafaiz@gmail.com', 'rdwnfakhrii20@gmail.com'];
    }

    // Products: anyone can browse the storefront; only admin mutates stock.
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Orders: a buyer may CREATE an order (dummy checkout), but cannot read
    // others' orders or change them. Only admin reads / processes orders.
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(['items', 'total', 'status', 'createdAt'])
                    && request.resource.data.total is number
                    && request.resource.data.total >= 0
                    && request.resource.data.status == 'baru';
      allow read, update, delete: if isAdmin();
    }

    // Reviews & complaints: a buyer may CREATE one (validated 1–5 stars);
    // everyone can read (storefront ratings); only admin edits/deletes.
    match /reviews/{reviewId} {
      allow create: if request.resource.data.keys().hasAll(['productId', 'productName', 'rating', 'comment', 'type', 'createdAt'])
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.type in ['ulasan', 'komplain'];
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
