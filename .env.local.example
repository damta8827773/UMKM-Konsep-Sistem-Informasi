NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=projectdamta.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=projectdamta
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=projectdamta.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=118530088464
NEXT_PUBLIC_FIREBASE_APP_ID=

# Emails allowed into admin (comma-separated). Everyone else is blocked.
NEXT_PUBLIC_ADMIN_EMAILS=damtafaiz@gmail.com,rdwnfakhrii20@gmail.com

# ── SERVER-ONLY (never prefix with NEXT_PUBLIC). Used only in backend/route code. ──
